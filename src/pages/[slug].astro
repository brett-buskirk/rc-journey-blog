---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { getPosts, formatDate, readingTime } from '../lib/posts';
import { categoryMeta } from '../lib/categories';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null, // older
      next: posts[i - 1] ?? null, // newer
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const cat = categoryMeta(post.data.categories[0]);
const mins = readingTime(post.body);
---

<Base title={post.data.title} image={post.data.coverImage.src} article>
  <article data-pagefind-body>
    {/* Cover */}
    <div class="relative h-[52vh] min-h-[22rem] w-full overflow-hidden">
      <Image
        src={post.data.coverImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgb(var(--c-scrim) / 0.55), rgb(var(--c-scrim) / 0.1));"></div>
    </div>

    {/* Title block */}
    <div class="mx-auto max-w-3xl px-5 md:px-8">
      <div class="-mt-16 relative rounded-lg bg-surface p-7 shadow-sm md:p-10">
        <p class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <a href={`/${cat.route}/`} class="eyebrow no-underline" style="color: var(--c-ochre);">{cat.label}</a>
          <span class="eyebrow">·</span>
          <span class="eyebrow">{formatDate(post.data.date)}</span>
          <span class="eyebrow">·</span>
          <span class="eyebrow">{mins} min read</span>
        </p>
        <h1 class="mt-4 text-4xl md:text-5xl" style='font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;'>
          {post.data.title}
        </h1>
      </div>
    </div>

    {/* Body */}
    <div class="mx-auto max-w-3xl px-5 py-12 md:px-8">
      <div class="prose-rcj mx-auto">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <p class="mt-12 flex flex-wrap gap-2">
          {post.data.tags.map((t) => (
            <span class="rounded-full border border-line px-3 py-1 font-mono text-xs text-muted">{t}</span>
          ))}
        </p>
      )}
    </div>

    {/* Prev / next */}
    <nav class="mx-auto max-w-3xl px-5 md:px-8" aria-label="More writing" data-pagefind-ignore>
      <hr class="horizon" />
      <div class="grid gap-6 py-10 sm:grid-cols-2">
        {prev ? (
          <a href={`/${prev.id}/`} class="group no-underline">
            <p class="eyebrow">← Earlier</p>
            <p class="mt-2 font-display text-xl group-hover:text-ochre">{prev.data.title}</p>
          </a>
        ) : <span />}
        {next && (
          <a href={`/${next.id}/`} class="group text-right no-underline sm:justify-self-end">
            <p class="eyebrow">Later →</p>
            <p class="mt-2 font-display text-xl group-hover:text-ochre">{next.data.title}</p>
          </a>
        )}
      </div>
    </nav>
  </article>
</Base>
