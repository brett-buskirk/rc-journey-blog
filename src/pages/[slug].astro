---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { getPosts, formatDate, readingTime } from '../lib/posts';
import { categoryMeta } from '../lib/categories';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null, // older
      next: posts[i - 1] ?? null, // newer
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const cat = categoryMeta(post.data.categories[0]);
const mins = readingTime(post.body);
---

<Base title={post.data.title} image={post.data.coverImage.src} article>
  <article data-pagefind-body>
    {/* Cover */}
    <div class="relative h-[52vh] min-h-[22rem] w-full overflow-hidden">
      <Image
        src={post.data.coverImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgb(var(--c-scrim) / 0.55), rgb(var(--c-scrim) / 0.1));"></div>
    </div>

    {/* Title block */}
    <div class="mx-auto max-w-3xl px-5 md:px-8">
      <div class="-mt-16 relative rounded-lg bg-surface p-7 shadow-sm md:p-10">
        <p class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <a href={`/${cat.route}/`} class="eyebrow no-underline" style="color: var(--c-ochre);">{cat.label}</a>
          <span class="eyebrow">·</span>
          <span class="eyebrow">{formatDate(post.data.date)}</span>
          <span class="eyebrow">·</span>
          <span class="eyebrow">{mins} min read</span>
        </p>
        <h1 class="mt-4 text-4xl md:text-5xl" style='font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;'>
          {post.data.title}
        </h1>
        <p class="mt-3 text-muted">By {post.data.author}</p>
      </div>
    </div>

    {/* Body */}
    <div class="mx-auto max-w-3xl px-5 py-12 md:px-8">
      <div class="prose-rcj mx-auto">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <p class="mt-12 flex flex-wrap gap-2">
          {post.data.tags.map((t) => (
            <span class="rounded-full border border-line px-3 py-1 font-mono text-xs text-muted">{t}</span>
          ))}
        </p>
      )}
    </div>

    {/* Prev / next */}
    <nav class="mx-auto max-w-3xl px-5 md:px-8" aria-label="More writing" data-pagefind-ignore>
      <hr class="horizon" />
      <div class="grid gap-6 py-10 sm:grid-cols-2">
        {prev ? (
          <a href={`/${prev.id}/`} class="group no-underline">
            <p class="eyebrow">← Earlier</p>
            <p class="mt-2 font-display text-xl group-hover:text-ochre">{prev.data.title}</p>
          </a>
        ) : <span />}
        {next && (
          <a href={`/${next.id}/`} class="group text-right no-underline sm:justify-self-end">
            <p class="eyebrow">Later →</p>
            <p class="mt-2 font-display text-xl group-hover:text-ochre">{next.data.title}</p>
          </a>
        )}
      </div>
    </nav>
  </article>
</Base>

<script>
  const grids = document.querySelectorAll<HTMLElement>('.gallery-grid');
  if (grids.length) {
    // Build lightbox DOM
    const overlay = document.createElement('div');
    overlay.id = 'lightbox';
    overlay.setAttribute('role', 'dialog');
    overlay.setAttribute('aria-modal', 'true');
    overlay.setAttribute('aria-label', 'Image viewer');
    overlay.innerHTML = `
      <button class="lb-close" aria-label="Close">&#x2715;</button>
      <button class="lb-prev" aria-label="Previous image">&#8249;</button>
      <button class="lb-next" aria-label="Next image">&#8250;</button>
      <figure>
        <img id="lb-img" alt="" />
        <figcaption id="lb-cap"></figcaption>
      </figure>
      <span class="lb-counter" id="lb-counter"></span>
    `;
    document.body.appendChild(overlay);

    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCap = document.getElementById('lb-cap')!;
    const lbCounter = document.getElementById('lb-counter')!;

    interface GalleryItem { src: string; alt: string; }
    const items: GalleryItem[] = [];
    let current = 0;

    grids.forEach((grid) => {
      grid.querySelectorAll<HTMLImageElement>('figure img').forEach((img) => {
        const idx = items.length;
        items.push({ src: img.src, alt: img.alt });
        img.parentElement!.addEventListener('click', () => open(idx));
      });
    });

    function open(idx: number) {
      current = idx;
      render();
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      overlay.focus();
    }

    function close() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    function render() {
      const { src, alt } = items[current];
      lbImg.src = src;
      lbImg.alt = alt;
      lbCap.textContent = alt;
      lbCounter.textContent = `${current + 1} / ${items.length}`;
    }

    function prev() { current = (current - 1 + items.length) % items.length; render(); }
    function next() { current = (current + 1) % items.length; render(); }

    overlay.querySelector('.lb-close')!.addEventListener('click', close);
    overlay.querySelector('.lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
    overlay.querySelector('.lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); next(); });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') prev();
      if (e.key === 'ArrowRight') next();
    });

    // Touch swipe
    let touchX = 0;
    overlay.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
    overlay.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) dx < 0 ? next() : prev();
    });
  }
</script>
