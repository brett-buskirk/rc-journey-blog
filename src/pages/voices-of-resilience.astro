---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Base
  title="Voices of Resilience"
  description="In-depth conversations with returning citizens who have navigated reentry successfully — stories of triumph, practical wisdom, and life after incarceration."
>
  <section class="mx-auto max-w-3xl px-5 pt-20 md:px-8">
    <PageHeader eyebrow="Community · Voices of Resilience" title="Returning citizen stories.">
      Amplifying the voices of people who have not only navigated reentry successfully but are
      truly thriving — raw honesty, hard-won wisdom, and lives transformed against formidable odds.
    </PageHeader>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12 md:px-8">
    <p class="eyebrow mb-6">Episodes</p>

    <div class="space-y-6">
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/2pq6Pc2FMzg2exuxwyPWp1?utm_source=generator"
        width="100%"
        height="232"
        frameborder="0"
        allowfullscreen
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
      ></iframe>
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/0d3zLqoUjy57Y2LIAwPN8k?utm_source=generator"
        width="100%"
        height="232"
        frameborder="0"
        allowfullscreen
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-20 md:px-8">
    <hr class="horizon" />
    <p class="mt-8 text-muted">
      More conversations are on the way. If you're a returning citizen with a story to share,
      <a href="mailto:brett@rcjourney.cloud">reach out</a>.
    </p>
  </section>
</Base>
