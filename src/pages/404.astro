---
import Base from '../layouts/Base.astro';
---
<Base title="Lost the trail" description="That page isn’t here.">
  <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col justify-center px-5 py-24 md:px-8">
    <p class="eyebrow">404 · Off the map</p>
    <h1 class="mt-4 text-6xl md:text-7xl" style='font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;'>
      You’ve wandered off the trail.
    </h1>
    <p class="mt-5 text-lg text-muted">No path here — but the long view’s still worth the walk back.</p>
    <hr class="horizon mt-10" />
    <p class="mt-8 flex flex-wrap gap-4">
      <a href="/" class="rounded-full bg-ochre px-6 py-3 font-mono text-xs uppercase tracking-widest text-[#1a130a] no-underline">Home</a>
      <a href="/blog/" class="rounded-full border border-line px-6 py-3 font-mono text-xs uppercase tracking-widest no-underline hover:border-ochre">All writing</a>
    </p>
  </section>
</Base>
