---
import Base from '../layouts/Base.astro';
---
<Base title="Lost the trail" description="That page isn’t here.">
  <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col justify-center px-5 py-24 md:px-8">
    <p class="eyebrow">404 · Off the map</p>
    <h1 class="title-display mt-4 text-6xl md:text-7xl">
      You’ve wandered off the trail.
    </h1>
    <p class="mt-5 text-lg text-muted">No path here — but the long view’s still worth the walk back.</p>
    <hr class="horizon mt-10" />
    <p class="mt-8 flex flex-wrap gap-4">
      <a href="/" class="btn">Home</a>
      <a href="/blog/" class="btn-ghost">All writing</a>
    </p>
  </section>
</Base>
