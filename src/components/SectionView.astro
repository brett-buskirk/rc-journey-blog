---
import Base from '../layouts/Base.astro';
import PostRow from './PostRow.astro';
import PageHeader from './PageHeader.astro';
import { getPostsByCategory } from '../lib/posts';
import { categoryMeta, type CategoryKey } from '../lib/categories';

interface Props { category: CategoryKey; }
const { category } = Astro.props;
const meta = categoryMeta(category);
const posts = await getPostsByCategory(category);
---

<Base title={meta.label} description={meta.blurb}>
  <section class="mx-auto max-w-4xl px-5 pt-20 md:px-8">
    <PageHeader
      eyebrow={`The Terrain · ${posts.length} ${posts.length === 1 ? 'piece' : 'pieces'}`}
      title={meta.label}
    >
      {meta.blurb}
    </PageHeader>
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-10 md:px-8">
    {posts.length === 0 ? (
      <p class="mt-12 text-muted">Nothing here yet — the trail’s still being walked.</p>
    ) : (
      <div class="mt-12 space-y-8">
        {posts.map((post, i) => (
          <>
            <PostRow post={post} />
            {i < posts.length - 1 && <hr class="border-0 border-t border-line/60" />}
          </>
        ))}
      </div>
    )}
  </section>
</Base>
