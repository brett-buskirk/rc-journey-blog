---
import { Image } from 'astro:assets';
import type { Post } from '../lib/posts';
import { stamp } from '../lib/posts';
import { categoryMeta } from '../lib/categories';

interface Props { post: Post; }
const { post } = Astro.props;
const cat = categoryMeta(post.data.categories[0]);
---

<article class="group">
  <a href={`/${post.id}/`} class="grid grid-cols-[1fr] items-center gap-5 no-underline sm:grid-cols-[8rem_1fr] sm:gap-7">
    <div class="hidden aspect-[4/3] overflow-hidden rounded-md sm:block">
      <Image
        src={post.data.coverImage}
        alt=""
        width={256}
        height={192}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>
    <div>
      <p class="flex flex-wrap items-center gap-x-3 gap-y-1">
        <span class="eyebrow">{stamp(post.data.date)}</span>
        <span class="eyebrow" style="color: var(--c-ochre);">{cat.label}</span>
      </p>
      <h3 class="mt-2 text-2xl leading-snug transition-colors group-hover:text-ochre">
        {post.data.title}
      </h3>
    </div>
  </a>
</article>
