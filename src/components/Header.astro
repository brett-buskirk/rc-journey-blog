---
import { Image } from 'astro:assets';
import { SITE, NAV } from '../lib/site';
import mark from '../assets/rcj-mark.png';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="sticky top-0 z-40 backdrop-blur-sm" style="background-color: color-mix(in srgb, var(--c-bg) 88%, transparent);">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-5 py-4 md:px-8">
    <a href="/" class="flex items-center gap-2.5 no-underline" aria-label={`${SITE.title} — home`}>
      <Image src={mark} alt="" width={36} height={36} class="h-9 w-9 object-contain" loading="eager" />
      <span class="font-display text-xl font-medium tracking-tight" style='font-variation-settings: "opsz" 40, "SOFT" 50;'>
        RC&nbsp;Journey
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
      {NAV.map((item) => (
        <a
          href={item.href}
          class="navlink no-underline transition-colors hover:text-ink"
          style={isActive(item.href) ? 'color: var(--c-ochre);' : ''}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/search/" class="navlink no-underline hover:text-ink" aria-label="Search">Search</a>
      <button
        id="theme-toggle"
        type="button"
        class="grid h-9 w-9 place-items-center rounded-full border border-line text-ink transition-colors hover:border-ochre"
        aria-label="Toggle color theme"
      >
        <span aria-hidden="true" class="text-base leading-none" data-theme-icon>☾</span>
      </button>
    </div>
  </div>
  <hr class="horizon" />
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const icon = btn?.querySelector('[data-theme-icon]');
  const sync = () => {
    if (icon) icon.textContent = document.documentElement.classList.contains('dark') ? '☀' : '☾';
  };
  sync();
  btn?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    sync();
  });
</script>
